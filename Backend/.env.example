# Server
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
DATABASE_NAME=marhas

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Rate Limiting (applied in production only; disabled when NODE_ENV=development)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=MARHAS <noreply@marhas.com>
APP_URL=http://localhost:5173

# Upload
UPLOAD_MAX_FILE_SIZE=10485760
UPLOAD_DIR=src/uploads
STORAGE_PROVIDER=local

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AWS S3 (optional)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Seed Admin
SEED_ADMIN_EMAIL=admin@marhas.com
SEED_ADMIN_PASSWORD=Marhas@Admin123
SEED_ADMIN_NAME=MARHAS Admin
