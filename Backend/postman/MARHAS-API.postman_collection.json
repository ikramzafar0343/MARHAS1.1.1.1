{
  "info": {
    "name": "MARHAS API",
    "description": "MARHAS luxury fashion e-commerce API collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "orderNumber", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": { "method": "GET", "url": "{{baseUrl}}/health" }
        },
        {
          "name": "Readiness",
          "request": { "method": "GET", "url": "{{baseUrl}}/health/ready" }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('accessToken', pm.response.json().data.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Customer\",\n  \"email\": \"customer@marhas.com\",\n  \"password\": \"Customer@123\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  pm.collectionVariables.set('accessToken', pm.response.json().data.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@marhas.com\",\n  \"password\": \"Customer@123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  pm.collectionVariables.set('adminToken', pm.response.json().data.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@marhas.com\",\n  \"password\": \"Marhas@Admin123\"\n}"
            },
            "url": "{{baseUrl}}/auth/admin/login"
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List Products",
          "request": { "method": "GET", "url": "{{baseUrl}}/products?category=new&page=1&limit=20" }
        },
        {
          "name": "Best Sellers",
          "request": { "method": "GET", "url": "{{baseUrl}}/products/best-sellers" }
        },
        {
          "name": "Get Product",
          "request": { "method": "GET", "url": "{{baseUrl}}/products/{{productId}}" }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Checkout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('orderNumber', pm.response.json().data.order.orderNumber);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"guest@marhas.com\",\n  \"phone\": \"+92 300 1234567\",\n  \"fullName\": \"Guest Customer\",\n  \"address\": \"12 Gulberg III\",\n  \"city\": \"Lahore\",\n  \"postalCode\": \"54000\",\n  \"paymentMethod\": \"cod\",\n  \"items\": [{ \"productId\": \"{{productId}}\", \"quantity\": 1, \"size\": \"M\", \"color\": \"Ivory Gold\" }]\n}"
            },
            "url": "{{baseUrl}}/orders"
          }
        },
        {
          "name": "Get Order",
          "request": { "method": "GET", "url": "{{baseUrl}}/orders/{{orderNumber}}" }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "List Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/orders"
          }
        },
        {
          "name": "List Inventory",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/inventory"
          }
        },
        {
          "name": "Analytics KPIs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/analytics/kpis?period=30d"
          }
        },
        {
          "name": "Dashboard Metrics",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/dashboard/metrics"
          }
        },
        {
          "name": "Get Storefront CMS",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/content/admin/storefront"
          }
        }
      ]
    },
    {
      "name": "Storefront",
      "item": [
        {
          "name": "Public Storefront",
          "request": { "method": "GET", "url": "{{baseUrl}}/content/storefront" }
        }
      ]
    },
    {
      "name": "Newsletter",
      "item": [
        {
          "name": "Subscribe",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"subscriber@marhas.com\",\n  \"source\": \"footer\"\n}"
            },
            "url": "{{baseUrl}}/newsletter/subscribe"
          }
        }
      ]
    }
  ]
}
